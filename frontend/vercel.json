{
  "framework": "nextjs",
  "buildCommand": "prisma migrate deploy && prisma generate && node scripts/create-active-sessions.js && next build",
  "crons": [
    {
      "path": "/api/cron/daily-report",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/keepalive",
      "schedule": "0 6 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/stripe/webhook",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
