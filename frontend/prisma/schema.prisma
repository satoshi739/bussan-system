generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

// NextAuth required tables
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(USER)
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  subscription        Subscription?
  activeSessions      ActiveSession[]
  purchaseRecords     PurchaseRecord[]
  saleRecords         SaleRecord[]
  scanHistories       ScanHistory[]
  profitCalcHistories ProfitCalcHistory[]
  ebayAccount         EbayAccount?
  monetizeProjects    MonetizeProject[]
  quickListings       QuickListing[]
  shippingLabels      ShippingLabel[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// Subscription / billing
model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 Plan               @default(FREE)
  status               SubscriptionStatus @default(INACTIVE)
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActiveSession {
  id         String   @id @default(cuid())
  userId     String
  sessionKey String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ユーザー活動記録
model PurchaseRecord {
  id           String   @id @default(cuid())
  userId       String
  itemName     String
  platform     String
  buyPrice     Float
  shippingCost Float    @default(0)
  otherFees    Float    @default(0)
  sellPrice    Float    @default(0)
  profit       Float    @default(0)
  roi          Float    @default(0)
  memo         String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SaleRecord {
  id        String   @id @default(cuid())
  userId    String
  itemName  String
  platform  String
  sellPrice Float
  buyPrice  Float    @default(0)
  profit    Float
  roi       Float    @default(0)
  memo      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScanHistory {
  id           String   @id @default(cuid())
  userId       String
  keyword      String
  platform     String
  resultsCount Int      @default(0)
  topRoi       Float    @default(0)
  topProfit    Float    @default(0)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProfitCalcHistory {
  id        String   @id @default(cuid())
  userId    String
  itemName  String
  buyPrice  Float
  sellPrice Float
  profit    Float
  roi       Float
  platform  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StripeEvent {
  id        String   @id @default(cuid())
  eventId   String   @unique
  createdAt DateTime @default(now())
}

model EbayAccount {
  id             String    @id @default(cuid())
  userId         String    @unique
  ebayUserId     String
  accessToken    String
  refreshToken   String
  tokenExpiresAt DateTime
  scopes         String[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ebayUserId])
}

model ContentItem {
  id          String    @id @default(cuid())
  platform    String // tiktok | instagram | x | dm
  theme       String    @default("")
  title       String
  body        String
  status      String    @default("draft") // draft | published
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum Plan {
  FREE
  LITE
  STANDARD
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

// ============================================================
// AI収益化コンテンツ生成機能 (MVP)
// ============================================================

model MonetizeProject {
  id                       String        @id @default(uuid()) @db.Uuid
  userId                   String        @map("user_id")
  name                     String        @db.VarChar(200)
  genre                    String        @db.VarChar(100)
  target                   String        @db.Text
  productUrl               String?       @map("product_url") @db.Text
  lpUrl                    String?       @map("lp_url") @db.Text
  blogUrl                  String?       @map("blog_url") @db.Text
  affiliateLink            String?       @map("affiliate_link") @db.Text
  memo                     String?       @db.Text
  latestGenerationResultId String?       @unique @map("latest_generation_result_id") @db.Uuid
  latestGeneratedAt        DateTime?     @map("latest_generated_at")
  status                   ProjectStatus @default(DRAFT)
  createdAt                DateTime      @default(now()) @map("created_at")
  updatedAt                DateTime      @updatedAt @map("updated_at")

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  latestResult GenerationResult?   @relation("ProjectLatestResult", fields: [latestGenerationResultId], references: [id], onDelete: SetNull)
  results      GenerationResult[]  @relation("ProjectResults")
  histories    GenerationHistory[]

  @@index([userId])
  @@index([status])
  @@map("monetize_projects")
}

model GenerationResult {
  id             String   @id @default(uuid()) @db.Uuid
  projectId      String   @map("project_id") @db.Uuid
  analysisJson   Json     @map("analysis_json")
  articleJson    Json     @map("article_json")
  snsJson        Json     @map("sns_json")
  reelJson       Json     @map("reel_json")
  lineJson       Json     @map("line_json")
  ctaJson        Json     @map("cta_json")
  complianceJson Json     @map("compliance_json")
  rawOutputJson  Json     @map("raw_output_json")
  promptVersion  String   @map("prompt_version") @db.VarChar(50)
  createdAt      DateTime @default(now()) @map("created_at")

  project          MonetizeProject    @relation("ProjectResults", fields: [projectId], references: [id], onDelete: Cascade)
  latestForProject MonetizeProject?   @relation("ProjectLatestResult")
  history          GenerationHistory?

  @@index([projectId])
  @@map("monetize_generation_results")
}

model GenerationHistory {
  id                 String                  @id @default(uuid()) @db.Uuid
  projectId          String                  @map("project_id") @db.Uuid
  generationResultId String?                 @unique @map("generation_result_id") @db.Uuid
  inputSnapshotJson  Json                    @map("input_snapshot_json")
  status             GenerationHistoryStatus
  errorCode          String?                 @map("error_code") @db.VarChar(50)
  errorMessage       String?                 @map("error_message") @db.Text
  promptVersion      String                  @map("prompt_version") @db.VarChar(50)
  startedAt          DateTime                @map("started_at")
  completedAt        DateTime?               @map("completed_at")
  createdAt          DateTime                @default(now()) @map("created_at")

  project MonetizeProject   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  result  GenerationResult? @relation(fields: [generationResultId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([status])
  @@map("monetize_generation_histories")
}

enum ProjectStatus {
  DRAFT
  READY
  GENERATING
  GENERATED
  ERROR

  @@map("project_status")
}

enum GenerationHistoryStatus {
  QUEUED
  PROCESSING
  SUCCESS
  FAILED

  @@map("generation_history_status")
}

// ============================================================
// 確認付きワンクリック出品 MVP (Quick Listing)
// ============================================================

model QuickListing {
  id              String              @id @default(cuid())
  userId          String

  // 入力データ
  sourceUrl       String?
  productName     String
  buyPrice        Int?
  estPrice        Int?
  condition       String?
  category        String?
  notes           String?
  weightG         Int?
  sizeCode        String?
  imageUrls       String[]            @default([])

  // AI生成データ
  aiTitle         String?
  aiDescription   String?             @db.Text
  aiCategories    String[]            @default([])
  aiKeywords      String[]            @default([])
  aiSuggestedPrice Int?
  aiProfitEstimate Int?
  aiShippingEstimate Int?
  aiWarnings      String[]            @default([])

  // 出品設定
  targetPlatform  String              @default("none")
  status          QuickListingStatus  @default(DRAFT)

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, updatedAt])
}

enum QuickListingStatus {
  DRAFT
  CONFIRMED
  CSV_EXPORTED
  API_PENDING
  PUBLISHED
}

model OnboardingEmailLog {
  id        String   @id @default(cuid())
  userId    String
  kind      String
  sentAt    DateTime @default(now())

  @@unique([userId, kind])
  @@index([userId])
}

// 管理者専用の設定ストア (APIキー等)
// secret=true の場合は value を暗号化して保存（AES-256-GCM）
model AppSetting {
  key         String   @id
  value       String   @db.Text
  secret      Boolean  @default(false)
  description String?
  updatedBy   String?
  updatedAt   DateTime @updatedAt
}

// 配送ラベル発行履歴 (ヤマトB2クラウド等の配送業者APIで発行した伝票の記録)
// 既存の types/shipping.Shipment (クライアントUI型) とは別概念
model ShippingLabel {
  id                  String   @id @default(cuid())
  userId              String
  externalOrderId     String
  carrier             String   @default("yamato")
  status              String   @default("pending")
  recipientName       String
  recipientPostalCode String
  recipientAddress    String
  recipientPhone      String
  packageName         String
  trackingNumber      String?
  trackingUrl         String?
  labelIssueId        String?
  labelPdfUrl         String?
  errorMessage        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([externalOrderId])
}
